{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UAI Message Schema",
  "version": "0.1.0",
  "description": "Universal Agent Interface — standard message envelope for all inter-agent communication",
  "type": "object",
  "required": [
    "id",
    "from",
    "to",
    "intent",
    "priority",
    "payload",
    "ts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique message ID (UUID v4)"
    },
    "from": {
      "type": "string",
      "description": "Sending agent ID",
      "enum": [
        "maxwell",
        "urahara",
        "cipher",
        "nova",
        "axiom",
        "sentinel",
        "system"
      ]
    },
    "to": {
      "type": "string",
      "description": "Receiving agent ID or 'broadcast'",
      "enum": [
        "maxwell",
        "urahara",
        "cipher",
        "nova",
        "axiom",
        "sentinel",
        "broadcast"
      ]
    },
    "intent": {
      "type": "string",
      "description": "Dot-namespaced intent string. Prefix determines routing.",
      "pattern": "^[a-z]+\\.[a-z_]+$",
      "examples": [
        "analyze.market_signal",
        "analyze.risk_score",
        "analyze.backtest",
        "security.audit",
        "security.threat_flag",
        "social.trend_report",
        "social.content_brief",
        "infra.deploy",
        "infra.debug",
        "report.executive_summary",
        "report.daily_brief",
        "broadcast.system_event"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "payload": {
      "type": "object",
      "description": "Intent-specific data. Schema varies by intent."
    },
    "context_ref": {
      "type": [
        "string",
        "null"
      ],
      "description": "Reference to parent task UUID (for chained tasks), or null"
    },
    "reply_to": {
      "type": [
        "string",
        "null"
      ],
      "description": "ID of the message this is responding to, or null"
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of message creation"
    },
    "ttl": {
      "type": "integer",
      "description": "Time-to-live in seconds before message expires and goes to DLQ",
      "default": 300,
      "minimum": 10,
      "maximum": 86400
    }
  }
}
