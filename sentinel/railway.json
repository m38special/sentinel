{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startupTimeout": 120,
    "webCommand": "python server.py"
  },
  "env": [
      {"key": "PORT", "value": "8080"},
      {"key": "REDIS_URL", "value": "{{REDIS_URL}}"},
      {"key": "SLACK_BOT_TOKEN", "value": "{{SLACK_BOT_TOKEN}}"},
      {"key": "SLACK_ALERT_CHANNEL", "value": "C0AHE2LQFRC"},
      {"key": "ALERT_THRESHOLD_SLACK", "value": "70"},
      {"key": "ALERT_THRESHOLD_ALL", "value": "85"}
  ]
}
